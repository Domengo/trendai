# MongoDB Configuration (REQUIRED)
# Get from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
# Example: mongodb+srv://admin:MyPassword123@cluster0.mongodb.net/trendai?retryWrites=true&w=majority&appName=Cluster0
MONGODB_URI=mongodb+srv://admin:password@cluster0.mongodb.net/trendai?retryWrites=true&w=majority&appName=Cluster0

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-characters
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://trendai-frontend.vercel.app

# Database Connection Timeouts (in milliseconds)
MONGODB_SERVER_SELECTION_TIMEOUT=5000
MONGODB_SOCKET_TIMEOUT=10000
